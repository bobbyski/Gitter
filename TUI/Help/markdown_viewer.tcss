MarkdownViewerModal {
    align: center middle;
}

#markdown_viewer_container {
    background: $surface;
    border: solid $primary;
    border-title-color: $primary;
    border-title-style: bold;
    padding: 1 2;
    width: 90%;
    height: 90%;
}

#markdown_viewer_scroll {
    width: 100%;
    height: 1fr;
    margin-bottom: 1;
}

#btn_close {
    width: 100%;
    height: 3;
}
